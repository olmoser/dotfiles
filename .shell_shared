# shellcheck shell=bash
# shellcheck disable=SC1090,SC1091

# Shared bootstrap sourced by both bash and zsh.
# Use only POSIX-compatible or bash/zsh-common syntax.
# Shell-specific options/completions should stay in .bash_profile/.zshrc.

for file in ~/.{path,exports,aliases,functions,extra}; do
  [ -r "$file" ] && [ -f "$file" ] && source "$file"
done
unset file

if [ -f /opt/homebrew/bin/brew ]; then
  eval "$(/opt/homebrew/bin/brew shellenv)"
elif [ -f /usr/local/bin/brew ]; then
  eval "$(/usr/local/bin/brew shellenv)"
fi

if [ -n "${ZSH_VERSION:-}" ]; then
  _shell_kind="zsh"
else
  _shell_kind="bash"
fi

# Go binaries (go install puts binaries here by default)
[ -d "${HOME}/go/bin" ] && export PATH="${PATH}:${HOME}/go/bin"

[ -f "${HOME}/.cargo/env" ] && source "${HOME}/.cargo/env"

# direnv (must be before prompt init to avoid hook ordering issues)
command -v direnv &>/dev/null && eval "$(direnv hook "${_shell_kind}")"

command -v starship &>/dev/null && eval "$(starship init "${_shell_kind}")"
command -v zoxide &>/dev/null && eval "$(zoxide init "${_shell_kind}" --cmd j)"

if command -v sk &>/dev/null; then
  _skim_ext="${_shell_kind}"
  for sk_bindings in \
    "$(brew --prefix 2>/dev/null)/opt/sk/share/skim/completion.${_skim_ext}" \
    "$(brew --prefix 2>/dev/null)/opt/sk/share/skim/key-bindings.${_skim_ext}" \
    "${HOME}/.skim/shell/completion.${_skim_ext}" \
    "${HOME}/.skim/shell/key-bindings.${_skim_ext}" \
    "/usr/share/skim/completion.${_skim_ext}" \
    "/usr/share/skim/key-bindings.${_skim_ext}"; do
    [ -f "$sk_bindings" ] && source "$sk_bindings"
  done
  unset sk_bindings _skim_ext
fi

# direnv (must be last — needs to wrap all other prompt hooks)
command -v direnv &>/dev/null && eval "$(direnv hook "${_shell_kind}")"

unset _shell_kind
